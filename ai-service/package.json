{
  "name": "ghostcomplete-ai-service",
  "version": "0.1.0",
  "private": true,
  "type": "module",
  "packageManager": "bun@1.3.13",
  "engines": {
    "bun": ">=1.3.0"
  },
  "scripts": {
    "build": "rm -rf dist && bun build src/index.ts --target=bun --outdir dist --sourcemap=external && bun build src/index.ts --target=bun --compile --outfile dist/ghostcomplete-sidecar",
    "dev": "bun run src/index.ts",
    "start": "bun run dist/index.js",
    "test": "bun test",
    "typecheck": "tsc -p tsconfig.json --noEmit"
  },
  "dependencies": {
    "ai": "^5.0.0"
  },
  "devDependencies": {
    "@types/bun": "^1.3.5",
    "msw": "^2.14.6",
    "typescript": "^5.9.0"
  }
}
