#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$ROOT/scripts/lib/load-env"
source "$ROOT/scripts/lib/keychain"
source "$ROOT/scripts/lib/sign-app"
LAUNCH=0
APP_NAME="GhostComplete"
APP_BUNDLE_ID="dev.octavian.GhostComplete"
INSTALL_PATH="/Applications/$APP_NAME.app"
APP_EXECUTABLE="$INSTALL_PATH/Contents/MacOS/$APP_NAME"

if [[ "${1:-}" == "--launch" ]]; then
  LAUNCH=1
fi

wait_for_quit() {
  for _ in {1..50}; do
    if ! pgrep -x "$APP_NAME" >/dev/null; then
      return 0
    fi
    sleep 0.1
  done
  return 1
}

quit_running_app() {
  if ! pgrep -x "$APP_NAME" >/dev/null; then
    return 0
  fi

  echo "$APP_NAME is running; quitting it before replacing the app bundle..."
  osascript -e "tell application id \"$APP_BUNDLE_ID\" to quit" >/dev/null 2>&1 &
  local osascript_pid="$!"
  for _ in {1..20}; do
    if ! kill -0 "$osascript_pid" >/dev/null 2>&1; then
      break
    fi
    sleep 0.1
  done
  if kill -0 "$osascript_pid" >/dev/null 2>&1; then
    kill "$osascript_pid" >/dev/null 2>&1 || true
  fi
  wait "$osascript_pid" >/dev/null 2>&1 || true

  if wait_for_quit; then
    echo "$APP_NAME quit cleanly."
    return 0
  fi

  echo "$APP_NAME did not quit after 5 seconds; terminating the process..."
  pkill -x "$APP_NAME" >/dev/null 2>&1 || true
  if wait_for_quit; then
    echo "$APP_NAME stopped."
    return 0
  fi

  echo "Could not stop $APP_NAME. Quit it manually and rerun bun run install:local." >&2
  exit 1
}

APP_PATH="$("$ROOT/scripts/build-app" | tail -n 1)"

quit_running_app

rm -rf "$INSTALL_PATH"
cp -R "$APP_PATH" "$INSTALL_PATH"
sign_ghostcomplete_app "$INSTALL_PATH"

if [[ -n "${AI_GATEWAY_API_KEY:-}" || -n "${OPENROUTER_API_KEY:-}" ]]; then
  store_api_keys_in_keychain "${AI_GATEWAY_API_KEY:-}" "${OPENROUTER_API_KEY:-}" "$APP_EXECUTABLE"
else
  echo "No API key was set; run scripts/set-api-key before using live completions."
fi

echo "Installed $INSTALL_PATH"
echo "Launch it, then grant Accessibility and Input Monitoring permissions to this exact app path when macOS prompts."
echo "If System Settings already shows GhostComplete but the app says blocked, run: bun run reset-perms"

if [[ "$LAUNCH" == "1" ]]; then
  open "$INSTALL_PATH"
  echo "Launched $INSTALL_PATH"
fi
