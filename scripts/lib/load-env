#!/usr/bin/env bash

if [[ -n "${GHOSTCOMPLETE_ENV_FILE:-}" ]]; then
  ENV_FILES=("$GHOSTCOMPLETE_ENV_FILE")
else
  ENV_FILES=("$ROOT/.env" "$ROOT/.env.local")
fi

for ENV_FILE in "${ENV_FILES[@]}"; do
  if [[ -f "$ENV_FILE" ]]; then
    set -a
    # shellcheck disable=SC1090
    source "$ENV_FILE"
    set +a
  fi
done
