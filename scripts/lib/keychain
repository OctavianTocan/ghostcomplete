#!/usr/bin/env bash

store_api_keys_in_keychain() {
  local gateway_key="${1:-}"
  local openrouter_key="${2:-}"
  local app_executable="${3:-}"

  if [[ -z "$gateway_key" && -z "$openrouter_key" ]]; then
    echo "AI_GATEWAY_API_KEY and OPENROUTER_API_KEY were empty; not storing a key in Keychain." >&2
    return 1
  fi

  if [[ -z "$app_executable" || ! -x "$app_executable" ]]; then
    echo "GhostComplete app executable was not found: ${app_executable:-<empty>}" >&2
    echo "Run bun run install:local first, then rerun bun run set-key." >&2
    return 1
  fi

  AI_GATEWAY_API_KEY="$gateway_key" OPENROUTER_API_KEY="$openrouter_key" "$app_executable" --store-api-key-and-exit
}

store_gateway_key_in_keychain() {
  store_api_keys_in_keychain "${1:-}" "" "${2:-}"
}
