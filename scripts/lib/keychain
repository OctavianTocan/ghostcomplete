#!/usr/bin/env bash

store_gateway_key_in_keychain() {
  local key="$1"
  local app_executable="${2:-}"

  if [[ -z "$key" ]]; then
    echo "AI_GATEWAY_API_KEY was empty; not storing it in Keychain." >&2
    return 1
  fi

  if [[ -z "$app_executable" || ! -x "$app_executable" ]]; then
    echo "GhostComplete app executable was not found: ${app_executable:-<empty>}" >&2
    echo "Run bun run install:local first, then rerun bun run set-key." >&2
    return 1
  fi

  AI_GATEWAY_API_KEY="$key" "$app_executable" --store-api-key-and-exit
}
