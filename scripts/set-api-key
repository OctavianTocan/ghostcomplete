#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$ROOT/scripts/lib/load-env"
source "$ROOT/scripts/lib/keychain"

APP_EXECUTABLE="/Applications/GhostComplete.app/Contents/MacOS/GhostComplete"

GATEWAY_KEY="${AI_GATEWAY_API_KEY:-}"
OPENROUTER_KEY="${OPENROUTER_API_KEY:-}"

if [[ -z "$GATEWAY_KEY" && -z "$OPENROUTER_KEY" ]]; then
  read -r -s -p "OPENROUTER_API_KEY (preferred; leave empty to enter Gateway key): " OPENROUTER_KEY
  echo
fi

if [[ -z "$GATEWAY_KEY" && -z "$OPENROUTER_KEY" ]]; then
  read -r -s -p "AI_GATEWAY_API_KEY: " GATEWAY_KEY
  echo
fi

if [[ -z "$GATEWAY_KEY" && -z "$OPENROUTER_KEY" ]]; then
  echo "No key provided." >&2
  exit 1
fi

store_api_keys_in_keychain "$GATEWAY_KEY" "$OPENROUTER_KEY" "$APP_EXECUTABLE"
