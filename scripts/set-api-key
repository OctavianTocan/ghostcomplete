#!/usr/bin/env bash
set -euo pipefail

ROOT="$(cd "$(dirname "${BASH_SOURCE[0]}")/.." && pwd)"
source "$ROOT/scripts/lib/load-env"
source "$ROOT/scripts/lib/keychain"

APP_EXECUTABLE="/Applications/GhostComplete.app/Contents/MacOS/GhostComplete"

KEY="${AI_GATEWAY_API_KEY:-}"

if [[ -z "$KEY" ]]; then
  read -r -s -p "AI_GATEWAY_API_KEY: " KEY
  echo
fi

if [[ -z "$KEY" ]]; then
  echo "No key provided." >&2
  exit 1
fi

store_gateway_key_in_keychain "$KEY" "$APP_EXECUTABLE"
